# Google Gemini API Configuration
GOOGLE_API_KEY= your_google_api_key_here

# Neo4j Database Configuration
NEO4J_URI= your_neo4j_uri_here
NEO4J_USERNAME= your_neo4j_username_here
NEO4J_PASSWORD= your_neo4j_password_here
NEO4J_DATABASE= your_neo4j_database_here
AURA_INSTANCEID= your_aura_instance_id_here
AURA_INSTANCENAME= your_aura_instance_name_here
PUBMED_EMAIL=
# Optional: Application Configuration
LOG_LEVEL= your_log_level_here
MAX_RETRIES= your_max_retries_here
TIMEOUT_SECONDS= your_timeout_seconds_here
